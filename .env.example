#* -------------------------------------------------------------------------- *#
#*                                Homestead Env                               *#
#* -------------------------------------------------------------------------- *#

#* This file is used to set environment variables for the Homestead project. *#
#* You can add any environment variables you need for your development and testing *#
#* environment here. These variables will be available to all applications in the project. *#


#* -------------------------------- Shared ------------------------------- *#
# Set your timezone (e.g. "America/Chicago", "UTC", "Europe/London")
TZ="America/Chicago"
# Set the default language/locale for your apps (e.g. "en", "en-US", "fr", "de")
LANG="en-US"
# Set the default currency code (e.g. "USD", "EUR", "GBP")
CURRENCY="USD"
# Set the default country code (e.g. "US", "GB", "FR")
COUNTRY="US"
# Set the default company name (used in logging, email templates, etc.)
COMPANY_NAME="Example Inc."
# Set the default environment (development, production, test)
NODE_ENV="development"


#* -------------------------------- Bunny CDN ------------------------------- *#
# If you use Bunny CDN for file storage, set these variables to enable the BunnyStorageService.
BUNNY_STORAGE_ZONE="storage_zone"
# Generate a strong access key in the Bunny dashboard and set it here:
BUNNY_ACCESS_KEY="your_bunny_access_key_here"
# The public URL for your Bunny storage zone, used to serve files. It usually looks like: https://yourzone.b-cdn.net
BUNNY_PUBLIC_URL="https://your_bunny_storage_zone.b-cdn.net" # e.g., https://myzone.b-cdn.net
# For local development, you can use the BunnyStorageService with a local directory. Set the root path for local storage here:
BUNNY_STORAGE_ROOT="/path/to/local/storage" # e.g., /homestead
BUNNY_REGION="new_york"

#* --------------------------------- API Server ------------------------------ *#
# The API server will run on this host and port. You can change these if needed, but make sure to update any related URLs (e.g. in the auth config).
HOST="http://localhost"
# The port your API server will listen on. Make sure this matches the PORT variable in your auth config if you're using the BetterAuthModule.
PORT_BACKEND="3000"
PORT_WEB_IAM="3001"
PORT_WEB_ADMIN="3002"
PORT_WEB_FOUNDRY="3003"
PORT_WEB_HOME="3004"


REGISTRATION_ENABLED="true" # Set to "false" to disable user registration 

#* --------------------------------- Database ------------------------------ *#
# PostgreSQL connection settings. These are used by the DatabaseModule to connect to your database. Make sure to set these according to your local setup.
# For local development, you can use the default PostgreSQL credentials. For production, make sure to use strong credentials and secure your database.
# The DB_SSL_MODE can be set to "disable" for local development, and should be set to "require" in production if your database supports SSL.
# The DB_MIGRATIONS_RUN variable controls whether TypeORM will automatically run pending migrations on app startup. This can be convenient for development, but you may want to set it to false in production and run migrations manually.
PGHOST="localhost"
PGPORT="5432"

PGUSER="postgres"
PGPASSWORD="postgres"
PGDATABASE="backend"
# PGSSLMODE can be "disable" (no SSL, for local development) or "require" (use SSL, for staging/production)
PGSSLMODE="disable"
# Connection pool settings
PGPOOL_MIN="2"
PGPOOL_MAX="10"
# Set to "true" to automatically run pending migrations on app startup. This is convenient for development, but in production you may want to set it to "false" and run migrations manually for better control.
PGMIGRATIONS_RUN="false" # Set to true to auto-run migrations on app

#* --------------------------------- Better Auth ------------------------------ *#
# BetterAuthModule configuration. This is used by the authentication module to set up JWT secrets, trusted origins for CORS, and other auth-related settings. Make sure to set a strong secret for BETTER_AUTH_SECRET in production, and update the URLs and trusted origins as needed.
BETTER_AUTH_URL="http://localhost:3000" # The base URL(s) where the auth server is accessible. Used in email templates and CORS config. You can specify multiple comma-separated URLs if your auth server is accessible from multiple origins (e.g. localhost for development and a custom domain for production).
BETTER_AUTH_API_KEY=00000000000000000000000000000000000 # Better-auth infra api key
# A strong secret is required to sign and verify JWT tokens. 
# Generate a random one for production! You can use a command like this to generate a secure random string:
#! bunx randomstring length=32  | openssl rand -base64 32 !#
BETTER_AUTH_SECRET="change-me-to-a-strong-32-char-or-more-secret"
# comma-separated list of allowed CORS origins for the auth server
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004"
BETTER_AUTH_COOKIE_DOMAIN=".example.com" # Set this to your domain (e.g. '.example.com') if you want to share auth cookies across subdomains in production. For local development, you can leave this unset or set it to 'localhost'.

AUTH_STEAM_SECRET="00000000000000000000000000"
#-----------------------------------------------
# https://console.cloud.google.com/apis/credentials
# Create credentials > OAuth client ID
# Authorized JavaScript origins: https://example.com && http://localhost:3000
# Authorized redirect URIs: https://example.com/api/auth/callback/google && http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="000000000000000000000000000000000000000000.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="00000000-000000000000000000000000"
#-----------------------------------------------
# https://discord.com/developers/applications
# Create credentials > OAuth client ID
# Authorized JavaScript origins: https://example.com && http://localhost:3000
# Authorized redirect URIs: https://example.com/api/auth/callback/discord && http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_ID="0000000000000000000"
AUTH_DISCORD_SECRET="00000000000000000000000000"
#------------------------------------------------
# https://github.com/settings/developers
# https://example.com/api/auth/callback/github
AUTH_GITHUB_ID="00000000000000000"
AUTH_GITHUB_SECRET="0000000000000000000000000000000000"
#-----------------------------------------------
AUTH_TWITCH_ID="000000000000000000"
AUTH_TWITCH_SECRET="00000000000000000000"


#* --------------------------------- Stripe ------------------------------ *#
PUBLIC_STRIPE_KEY_LIVE="00000000000000000000000000000000000000"
STRIPE_SECRET_KEY_LIVE="00000000000000000000"
#------------------------------------------------
PUBLIC_STRIPE_KEY_TEST="00000000000000000000000000000000"
STRIPE_SECRET_KEY_TEST="00000000000000000000000000000"
STRIPE_WEBHOOK_SECRET_TEST="0000000000000000000000000"
