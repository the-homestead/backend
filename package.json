{
  "name": "@homestead/backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "n": "nest",
    "n:g": "nest generate",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch --inspect-brk=0.0.0.0:9229",
    "start:prod": "node dist/main",
    "dev": "nest start --watch",
    "repl": "bun start -- --entryFile repl",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/bun test --runInBand",
    "test:e2e": "bun test ./test/",
    "auth:gen": "bunx auth@latest generate --config ./src/modules/auth/auth.main.ts",
    "auth:mig": "bunx auth@latest migrate --config ./src/modules/auth/auth.main.ts",
    "to": "bun typeorm",
    "to:generate": "bun typeorm migration:generate -d ./src/modules/database/data-source.ts ./src/migrations/$(date +%s)-migration",
    "to:create": "bun typeorm migration:create ./migrations/",
    "to:run": "bun typeorm migration:run     -d ./src/modules/database/data-source.ts",
    "to:show": "bun typeorm migration:show     -d ./src/modules/database/data-source.ts",
    "to:revert": "bun typeorm migration:revert  -d ./src/modules/database/data-source.ts",
    "to:version": "bun typeorm version",
    "to:schema:sync": "bun typeorm schema:sync  -d ./src/modules/database/data-source.ts",
    "to:schema:log": "bun typeorm schema:log  -d ./src/modules/database/data-source.ts",
    "to:schema:drop": "bun typeorm schema:drop  -d ./src/modules/database/data-source.ts",
    "to:query": "bun typeorm query",
    "doc:gen": " bunx @compodoc/compodoc -p ./tsconfig.doc.json -c ./.comdocrc.json",
    "doc:serve": "bunx @compodoc/compodoc -s -o -p ./tsconfig.doc.json -c ./.comdocrc.json",
    "doc:watch": "bunx @compodoc/compodoc -w -p ./tsconfig.doc.json -c ./.comdocrc.json"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.5.4",
    "@better-auth/i18n": "^1.5.4",
    "@better-auth/oauth-provider": "^1.5.4",
    "@better-auth/passkey": "^1.5.4",
    "@better-auth/stripe": "^1.5.4",
    "@bunny.net/storage-sdk": "^0.3.1",
    "@hedystia/better-auth-typeorm": "^0.7.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/devtools-integration": "^0.2.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "@thallesp/nestjs-better-auth": "^2.4.0",
    "axios": "^1.13.6",
    "better-auth": "^1.5.4",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "nestjs-pino": "^4.6.0",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^20.4.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.2.1",
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.25",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@simplewebauthn/types": "^12.0.0",
    "@types/bun": "^1.3.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
